# URL PostgreSQL (comptes, Elo, historique de parties)
# Exemple local Docker : postgresql://4mation:4mation_dev@127.0.0.1:5432/4mation
# DATABASE_URL=

# Introspection SSO Lab211 (défaut : auth.lab211.fr, site 4mation)
# LAB211_AUTH_BASE=https://auth.lab211.fr
# LAB211_SITE_KEY=4mation

# Multijoueur en ligne (Socket.IO, matchmaking in-memory — un worker recommandé)
# REDIS_URL=  # réservé pour scaling futur

# Sessions de jeu (SQLite, partagé entre workers Gunicorn)
# SESSION_DB_PATH=./data/sessions.db

# Tablebase endgame (lecture seule)
# TABLEBASE_DB_PATH=./data/tablebase.db
